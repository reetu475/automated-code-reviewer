PORT=5000
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Comma-separated fallback models when one is overloaded (optional)
GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=YOUR_CHROMA_API_KEY
CHROMA_TENANT=0d59f2f2-3122-4407-b10f-076b2471c986
CHROMA_DATABASE=aii

# LangSmith Tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=YOUR_LANGSMITH_API_KEY
LANGSMITH_PROJECT="automated-code"
